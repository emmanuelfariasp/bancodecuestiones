<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>NeuroQuiz - acceso, progreso, PDF y estadísticas</title>
<style>
:root {
  --bg:#f4f7fb; --card:#ffffff; --ink:#172033; --muted:#637083; --line:#d9e0ea;
  --primary:#315f9f; --primary2:#e9f1ff; --accent:#203a62; --good:#147545; --bad:#b42318; --warn:#946200;
  --shadow:0 12px 35px rgba(20,35,60,.12); --radius:22px;
}
*{box-sizing:border-box}
body{margin:0;font-family:Inter,Arial,Helvetica,sans-serif;background:var(--bg);color:var(--ink)}
.wrap{max-width:1120px;margin:0 auto;padding:24px}
.hero{background:#fff;color:var(--ink);border:1px solid var(--line);border-radius:24px;padding:22px;box-shadow:var(--shadow);position:relative;overflow:hidden}
.hero h1{margin:0 0 6px;font-size:clamp(26px,4vw,38px);letter-spacing:-.4px}
.hero p{margin:6px 0;line-height:1.45;color:var(--muted);max-width:840px}
.panel{margin-top:20px;background:var(--card);border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);padding:22px}
.menuTitle{display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:flex-end}
.menuTitle h2{margin:0;font-size:26px}
.menuTitle p{margin:6px 0 0;color:var(--muted)}
.creatorNote{margin-top:12px;padding:12px 14px;border:1px solid var(--line);border-radius:16px;background:#f8fafc;color:#344054;font-weight:700;line-height:1.45}
.groupTitle{margin:22px 0 4px;font-size:18px;letter-spacing:-.2px;color:#172033;display:flex;align-items:center;gap:8px}
.groupTitle:before{content:"";width:8px;height:8px;border-radius:999px;background:var(--primary);display:inline-block}
.groupHint{margin:0;color:var(--muted);font-size:13px;line-height:1.35}
.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:12px;margin-top:16px}
.generalGrid{grid-template-columns:repeat(auto-fit,minmax(260px,1fr));margin-top:12px}
.square{min-height:172px;border:1px solid var(--line);background:#fff;border-radius:18px;padding:14px;box-shadow:0 4px 12px rgba(20,35,60,.05);transition:.16s ease;display:flex;flex-direction:column;justify-content:space-between;gap:12px}
.square:hover{transform:translateY(-2px);border-color:#8fb0df;box-shadow:0 12px 25px rgba(20,35,60,.12)}
.square.general{border-color:#b9c9e3;background:#fbfdff}
.square .num{min-width:36px;height:36px;border-radius:13px;background:var(--primary2);color:var(--primary);display:inline-grid;place-items:center;font-weight:900;padding:0 10px}
.square h3{font-size:16px;margin:12px 0 6px;line-height:1.25}
.square p{margin:0;color:var(--muted);font-size:12.5px;line-height:1.35}
.square .cardSub{display:block;color:var(--muted);font-size:12px;line-height:1.25;margin-top:4px;font-weight:600}
.square.score-ok{background:#ecfdf3;border-color:#75d69d;box-shadow:0 8px 18px rgba(20,117,69,.12)}
.square.score-bad{background:#fff1f0;border-color:#f79991;box-shadow:0 8px 18px rgba(180,35,24,.10)}
.square.score-ok .num{background:#d1fadf;color:#067647}
.square.score-bad .num{background:#fee4e2;color:#b42318}
.cardActions{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:4px}
.cardActions .btn{padding:10px 9px;font-size:13px;border-radius:12px}
.cardActions .btn.view{grid-column:1 / -1;background:#eef2f7;color:#344054}
.topline{display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;margin-bottom:10px}
.pill{display:inline-flex;align-items:center;gap:8px;padding:8px 12px;border-radius:999px;background:var(--primary2);color:var(--primary);font-weight:800;font-size:14px}
.modeTag{display:inline-flex;margin-left:8px;align-items:center;padding:7px 10px;border-radius:999px;font-weight:800;font-size:13px;border:1px solid var(--line);background:#fff;color:#344054}
.modeTag.study{background:#ecfdf3;color:#147545;border-color:#abefc6}
.modeTag.exam{background:#fff4d6;color:#946200;border-color:#f5d47a}
.progressbar{height:12px;background:#eef2f7;border-radius:999px;overflow:hidden;margin:14px 0 4px}
.progressbar > div{height:100%;width:0%;background:linear-gradient(90deg,#315f9f,#67a4ff);transition:width .25s ease}
.question{font-size:22px;line-height:1.35;margin:18px 0 16px;font-weight:800}
.options{display:grid;gap:12px}
.option{width:100%;text-align:left;border:1px solid var(--line);background:#fff;border-radius:15px;padding:14px 16px;font-size:15.5px;line-height:1.34;cursor:pointer;transition:.14s ease;min-height:76px;display:flex;align-items:center}
.option:hover{border-color:#93a4ba;transform:translateY(-1px)}
.option.selected{background:#e9f1ff;border-color:#315f9f;box-shadow:0 0 0 2px rgba(49,95,159,.08)}
.option.correct{background:#ecfdf3;border-color:#75d69d}
.option.wrong{background:#fff1f0;border-color:#f79991}
.option.dim{opacity:.75}
.option:disabled{cursor:default;transform:none}
.feedback{display:none;margin-top:16px;border-radius:16px;padding:16px;border:1px solid var(--line);line-height:1.5}
.feedback.good{display:block;background:#ecfdf3;border-color:#abefc6}
.feedback.bad{display:block;background:#fff1f0;border-color:#fecdca}
.feedback.info{display:block;background:#f8fafc;border-color:var(--line)}
.feedback strong{display:block;margin-bottom:6px}
.actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:18px}
.btn{border:0;background:var(--primary);color:#fff;font-weight:800;border-radius:13px;padding:12px 16px;cursor:pointer;transition:.12s ease;text-decoration:none;display:inline-flex;align-items:center;justify-content:center}
.btn:hover{filter:brightness(.98);transform:translateY(-1px)}
.btn.secondary{background:#eef2f7;color:#344054}
.btn.warn{background:#fff4d6;color:var(--warn);border:1px solid #f5d47a}
.btn:disabled{opacity:.45;cursor:not-allowed;transform:none}
.hidden{display:none!important}
.stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:14px;margin-top:16px}
.stat{background:#f8fafc;border:1px solid var(--line);border-radius:18px;padding:16px}
.stat h3{margin:0 0 6px;font-size:30px}
.stat p{margin:0;color:var(--muted)}
.review details{border:1px solid var(--line);border-radius:15px;background:#fff;padding:12px 14px;margin:10px 0}
.review summary{cursor:pointer;font-weight:800}
.topicTag{display:inline-flex;background:#eef2f7;color:#344054;border-radius:999px;padding:6px 10px;margin:5px 5px 0 0;font-size:12px;font-weight:700}
.small{font-size:13px;color:var(--muted)}
.footerNote{text-align:center;color:var(--muted);font-size:12px;margin:18px 0 4px}
.questionList{margin-top:18px;border:1px solid var(--line);border-radius:18px;background:#f8fafc;padding:14px;max-height:560px;overflow:auto}
.questionList h3{margin:2px 0 10px;font-size:18px}
.listItem{background:#fff;border:1px solid var(--line);border-radius:14px;padding:12px 14px;margin:10px 0;line-height:1.42}
.listItem .listQ{font-weight:800;margin-bottom:8px}
.listItem ol{margin:6px 0 0 22px;padding:0}
.listItem li{margin:5px 0}
.listTop{display:flex;justify-content:space-between;gap:10px;align-items:center;flex-wrap:wrap;margin-bottom:8px}
.modeHelp{margin:14px 0 0;padding:12px 14px;background:#f8fafc;border:1px solid var(--line);border-radius:16px;color:#344054;line-height:1.45}

.miniProgress{margin-top:8px;font-size:12px;color:#344054;font-weight:700}
.miniProgress .track{height:7px;background:#e4e7ec;border-radius:999px;overflow:hidden;margin-top:5px;border:1px solid #d0d5dd}
.miniProgress .fill{height:100%;background:linear-gradient(90deg,#315f9f,#67a4ff);border-radius:999px;width:0%}
.statusBadge{display:inline-flex;align-items:center;gap:5px;border-radius:999px;padding:5px 9px;font-size:12px;font-weight:900;border:1px solid var(--line)}
.statusBadge.ok{background:#ecfdf3;color:#067647;border-color:#75d69d}
.statusBadge.bad{background:#fff1f0;color:#b42318;border-color:#f79991}
.statusBadge.pending{background:#eef2f7;color:#667085;border-color:#d0d5dd}
.listItem.doneOk{border-color:#75d69d;background:#f6fef9}
.listItem.doneBad{border-color:#f79991;background:#fffbfa}
.listHead{display:flex;justify-content:space-between;gap:10px;align-items:flex-start;flex-wrap:wrap;margin-bottom:8px}
.listAnswerNote{font-size:13px;margin-top:8px;padding:8px 10px;border-radius:12px;background:#f8fafc;border:1px solid var(--line);color:#344054}
.listItem li.listCorrect{font-weight:900;color:#067647}
.listItem li.listWrong{font-weight:900;color:#b42318;text-decoration:line-through;text-decoration-thickness:1px}


.progressPanel{margin:12px 0 14px;border:1px solid var(--line);border-radius:18px;background:#f8fafc;padding:12px 14px}
.statsGrid{display:grid;grid-template-columns:repeat(4,minmax(90px,1fr));gap:8px;margin-bottom:10px}
.statBox{border:1px solid var(--line);border-radius:14px;background:#fff;padding:9px 10px;min-height:58px}
.statBox b{display:block;font-size:18px;line-height:1;color:var(--ink)}
.statBox span{display:block;margin-top:5px;font-size:11.5px;font-weight:800;color:var(--muted);text-transform:uppercase;letter-spacing:.3px}
.statBox.ok b{color:#067647}.statBox.bad b{color:#b42318}.statBox.pending b{color:#667085}
.progressLabel{display:flex;justify-content:space-between;gap:10px;align-items:center;font-size:13px;color:var(--muted);font-weight:800;margin-bottom:7px}
.progressLabel strong{color:var(--ink)}
.miniProgress .miniStats{display:flex;gap:7px;flex-wrap:wrap;margin-top:6px;font-size:11.5px;font-weight:800;color:var(--muted)}
.miniProgress .miniStats .ok{color:#067647}.miniProgress .miniStats .bad{color:#b42318}
.themeNote{margin-top:10px;font-size:12.5px;color:var(--muted);font-weight:700}

.loginPanel{max-width:620px;margin:20px auto 0;text-align:left}
.loginPanel h2{margin:0 0 8px;font-size:26px;letter-spacing:-.3px}
.loginPanel p{color:var(--muted);line-height:1.45}
.nameForm{display:flex;gap:10px;flex-wrap:wrap;margin-top:16px}
.nameInput{flex:1;min-width:220px;border:1px solid var(--line);border-radius:14px;padding:13px 14px;font-size:16px;background:var(--card);color:var(--ink);outline:none}
.nameInput:focus{border-color:var(--primary);box-shadow:0 0 0 3px rgba(49,95,159,.12)}
.greetingBox{margin:14px 0 0;padding:14px 16px;border:1px solid #b9c9e3;border-radius:18px;background:#f0f6ff;color:#203a62;font-weight:800;line-height:1.45}
.greetingBox .helloName{font-size:18px;color:var(--primary)}
.menuActions{display:flex;gap:10px;flex-wrap:wrap;align-items:center}
.analyticsNote{margin-top:10px;font-size:12px;color:var(--muted);line-height:1.4}

@media (prefers-color-scheme: dark){
  :root{
    --bg:#0b1120; --card:#101828; --ink:#f2f4f7; --muted:#98a2b3; --line:#263244;
    --primary:#8ab4f8; --primary2:#1d2b46; --accent:#c7d7fe; --good:#66d19e; --bad:#ff8a80; --warn:#ffd166;
    --shadow:0 14px 35px rgba(0,0,0,.34);
  }
  body{background:linear-gradient(180deg,#0b1120,#0f172a);color:var(--ink)}
  .hero,.panel{background:var(--card);border-color:var(--line)}
  .hero p,.menuTitle p,.groupHint,.small,.footerNote,.square p,.square .cardSub{color:var(--muted)}
  .creatorNote,.modeHelp,.questionList,.feedback.info,.listAnswerNote,.progressPanel,.loginPanel{background:#111a2c;color:#d0d5dd;border-color:var(--line)}
  .groupTitle{color:var(--ink)}
  .nameInput{background:#182235;color:var(--ink);border-color:var(--line)}
  .greetingBox{background:#111a2c;color:#d0d5dd;border-color:#2d4263}
  .greetingBox .helloName{color:#8ab4f8}
  .square,.listItem,.review,.statBox,.option{background:#182235;color:var(--ink);border-color:var(--line)}
  .square.general{background:#16233a;border-color:#2d4263}
  .square:hover{border-color:#5585c4;box-shadow:0 14px 28px rgba(0,0,0,.32)}
  .btn.secondary,.cardActions .btn.view{background:#1d2939;color:#e4e7ec;border:1px solid var(--line)}
  .btn.warn{background:#ad7800;color:#fff}
  .modeTag{background:#182235;color:#e4e7ec;border-color:var(--line)}
  .modeTag.study{background:rgba(20,117,69,.22);color:#7ee2ac;border-color:rgba(126,226,172,.35)}
  .modeTag.exam{background:rgba(148,98,0,.25);color:#ffd166;border-color:rgba(255,209,102,.35)}
  .progressbar,.miniProgress .track{background:#263244;border-color:#334155}
  .progressbar > div,.miniProgress .fill{background:linear-gradient(90deg,#8ab4f8,#67e8f9)}
  .option:hover{border-color:#6ea8fe;background:#1c2940}
  .option.selected{background:#1d2b46;border-color:#8ab4f8;box-shadow:0 0 0 2px rgba(138,180,248,.14)}
  .option.correct,.feedback.good,.listItem.doneOk,.square.score-ok{background:rgba(20,117,69,.18);border-color:rgba(126,226,172,.55)}
  .option.wrong,.feedback.bad,.listItem.doneBad,.square.score-bad{background:rgba(180,35,24,.18);border-color:rgba(255,138,128,.55)}
  .square.score-ok .num{background:rgba(20,117,69,.24);color:#7ee2ac}.square.score-bad .num{background:rgba(180,35,24,.24);color:#ff8a80}
  .statusBadge.ok{background:rgba(20,117,69,.22);color:#7ee2ac;border-color:rgba(126,226,172,.45)}
  .statusBadge.bad{background:rgba(180,35,24,.22);color:#ff8a80;border-color:rgba(255,138,128,.45)}
  .statusBadge.pending{background:#1d2939;color:#cbd5e1;border-color:#334155}
  .listItem li.listCorrect,.miniProgress .miniStats .ok,.statBox.ok b{color:#7ee2ac}
  .listItem li.listWrong,.miniProgress .miniStats .bad,.statBox.bad b{color:#ff8a80}
  .statBox.pending b{color:#cbd5e1}
}
@media(max-width:760px){.statsGrid{grid-template-columns:repeat(2,1fr)}}

@media(max-width:620px){.wrap{padding:14px}.hero{padding:20px}.panel{padding:16px}.grid{grid-template-columns:1fr;gap:10px}.square{min-height:auto;padding:13px}.question{font-size:19px}.cardActions{grid-template-columns:1fr}.cardActions .btn.view{grid-column:auto}}
</style>
</head>
